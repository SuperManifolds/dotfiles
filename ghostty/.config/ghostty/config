theme = Tomorrow Night
font-family = "JetBrains Mono NerdFont Mono"
background-opacity = 0.95
background-blur-radius = 25
macos-option-as-alt = true
background = 15171a
cursor-style = bar
window-padding-x = 4
window-colorspace = display-p3
copy-on-select = false
keybind = shift+right=unbind
keybind = shift+left=unbind
keybind = shift+down=unbind
keybind = shift+up=unbind
keybind = shift+enter=text:\n

# Mac-style tab/window shortcuts (Super = Cmd on mac, Super on Linux)
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+n=new_window
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = super+6=goto_tab:6
keybind = super+7=goto_tab:7
keybind = super+8=goto_tab:8
keybind = super+9=goto_tab:9
keybind = super+bracket_left=previous_tab
keybind = super+bracket_right=next_tab
keybind = super+shift+bracket_left=move_tab:-1
keybind = super+shift+bracket_right=move_tab:1
